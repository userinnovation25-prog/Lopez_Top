# ============================================
# CONFIGURACIÓN DEL PROYECTO LOPEZTOP
# ============================================
# Este archivo es un TEMPLATE. Copia este contenido
# a un archivo .env en la raíz del proyecto y
# completa con tus valores reales.
#
# ⚠️ NUNCA comitas el archivo .env a git
# ⚠️ Agrega .env a .gitignore

# ============================================
# APLICACIÓN
# ============================================
# Puerto del servidor
PORT=5000

# Ambiente: development, staging, production
NODE_ENV=development

# ============================================
# BASE DE DATOS
# ============================================
# URI de conexión a MongoDB
# Ejemplo: mongodb://usuario:contraseña@host:puerto/baseDatos
# Para MongoDB Atlas: mongodb+srv://usuario:contraseña@cluster.mongodb.net/baseDatos?retryWrites=true&w=majority
MONGODB_URI=your-mongodb-uri-here

# Nombre de la base de datos
DB_NAME=lopeztop

# ============================================
# AUTENTICACIÓN JWT
# ============================================
# Secret key para firmar tokens JWT
# Genera una clave segura: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-min-32-characters-long

# Tiempo de expiración del token
# Ejemplos: 7d (7 días), 24h (24 horas), 1h (1 hora)
JWT_EXPIRES_IN=7d

# ============================================
# CORS - ORÍGENES PERMITIDOS
# ============================================
# Lista de orígenes separados por coma
# Ejemplo: http://localhost:3000,https://lopeztop.com,https://tu-proyecto.vercel.app
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8000,http://127.0.0.1:5500,http://127.0.0.1:5501

# ============================================
# LOGGING
# ============================================
# Nivel de logging: debug, info, warn, error
LOG_LEVEL=debug

# ============================================
# ADMIN INICIAL (Opcional)
# ============================================
# Si deseas especificar contraseña para el admin inicial en seed.js
# Si no se proporciona, se genera una aleatoria
# ADMIN_PASSWORD=tu-contraseña-segura

# ============================================
# EMAIL (Opcional - Para notificaciones futuras)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASS=tu-app-password

# ============================================
# API EXTERNA (Opcional)
# ============================================
# GOOGLE_MAPS_API_KEY=your-api-key
